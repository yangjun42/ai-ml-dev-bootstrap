# Conservative defaults for restricted environments.
export AI_DEV_PROFILE="enterprise"
export HF_HOME="${HOME}/models/huggingface"
export HF_HUB_DISABLE_TELEMETRY="1"
export DO_NOT_TRACK="1"
export WANDB_MODE="offline"
export MLFLOW_TRACKING_URI="file://${HOME}/mlruns"
export TOKENIZERS_PARALLELISM="false"
export UV_LINK_MODE="copy"
# Uncomment and set to internal mirrors when available:
# export UV_INDEX_URL="https://pypi.internal.example/simple"
# export UV_EXTRA_INDEX_URL=""
# export PIP_INDEX_URL="$UV_INDEX_URL"
