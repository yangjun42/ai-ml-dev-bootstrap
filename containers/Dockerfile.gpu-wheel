# GPU-runtime image that relies on PyTorch CUDA wheels and host NVIDIA Container Toolkit.
# Build with e.g. docker build -f containers/Dockerfile.gpu-wheel -t ai-ml-dev:gpu .
FROM python:3.12-slim-bookworm

ARG PYTORCH_CUDA_INDEX=https://download.pytorch.org/whl/cu130
ENV UV_LINK_MODE=copy \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /usr/local/bin/

RUN apt-get update && apt-get install -y --no-install-recommends \
    git git-lfs curl ca-certificates build-essential cmake ninja-build pkg-config ffmpeg \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace
COPY templates/ai-starter/ /workspace/

RUN uv venv --python 3.12 \
  && uv pip install -r requirements/base.txt -r requirements/llm.txt -r requirements/dev.txt -r requirements/mlsys.txt \
  && uv pip install torch torchvision torchaudio --index-url ${PYTORCH_CUDA_INDEX}

CMD ["uv", "run", "python", "scripts/check_env.py"]
